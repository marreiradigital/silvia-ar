# ── HTTP ────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
# Domínio do CLIENTE (onde o index.html do jogo é servido)
CORS_ORIGIN=https://silvia.marreira.link

# ── MySQL ───────────────────────────────────────────────
# Em dev, deixe DB_HOST vazio pra rodar em modo memória (sem MySQL local).
# Em produção, preencher com as credenciais da VPS.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=silvia
DB_PASSWORD=changeme
DB_NAME=silvia
